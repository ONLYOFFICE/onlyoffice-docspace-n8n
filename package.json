    "typescript": "5.9.2"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  },
  "n8n": {
    "n8nNodesApiVersion": 1,
    "strict": true,
    "credentials": [
      "dist/credentials/OnlyofficeDocspaceApiKeyApi.credentials.js",
      "dist/credentials/OnlyofficeDocspaceBasicAuthApi.credentials.js",
      "dist/credentials/OnlyofficeDocspaceOAuth2Api.credentials.js",
      "dist/credentials/OnlyofficeDocspacePersonalAccessTokenApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/OnlyofficeDocspace/OnlyofficeDocspace.node.js",
      "dist/nodes/OnlyofficeDocspace/OnlyofficeDocspaceTrigger.node.js"
